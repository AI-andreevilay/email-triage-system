# HTTP
HTTP_PORT=8080

# Infrastructure
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/email_triage?sslmode=disable
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Email source: mock or gmail
EMAIL_SOURCE=mock

# Gmail reader settings. Required only when EMAIL_SOURCE=gmail.
GMAIL_CREDENTIALS_FILE=secrets/gmail_credentials.json
GMAIL_TOKEN_FILE=secrets/gmail_token.json
GMAIL_USER_ID=me
GMAIL_READ_MAX_RESULTS=100
GMAIL_READ_QUERY=in:inbox -in:trash

# Number of concurrent Gmail label apply operations inside one label-worker process.
LABEL_WORKER_CONCURRENCY=4
